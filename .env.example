# Copy to .env.local for integration mode (real agentos-api).
# Origin only — the OpenAPI paths already include the /api/v1 prefix.
# The agos `[api] cors_allowed_origins` must include this panel's origin
# (e.g. http://localhost:5173) — see plan 01-browser-auth-and-api-keys.
VITE_API_BASE=http://localhost:8080
VITE_WS_BASE=ws://localhost:8080
VITE_REFRESH_ENABLED=false
